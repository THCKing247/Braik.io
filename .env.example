# Copy to ".env.local" for local Next.js (never commit .env or .env*.local).
# Production: set the same keys in your host (e.g. Netlify) environment UI.

# --- Postmark (server-side transactional email) ---
# Server API token from Postmark → Server → API Tokens
POSTMARK_SERVER_TOKEN=
# Verified sender, e.g. Braik <noreply@apextsgroup.com>
POSTMARK_FROM_EMAIL=
# Optional
# POSTMARK_REPLY_TO_EMAIL=
# POSTMARK_SUPPORT_EMAIL=
POSTMARK_MESSAGE_STREAM=outbound
